# fsdbench uses LiteLLM, which reads standard provider env vars.

# OpenAI (used by the QA agent, the LLM judge, and embeddings by default)
OPENAI_API_KEY=sk-...

# Optional: route OpenAI-compatible calls through a proxy or alternate base URL
# (e.g. a local LiteLLM proxy). Leave unset to hit the OpenAI API directly.
# OPENAI_BASE_URL=http://localhost:4000

# Optional: custom "clarin/" provider prefix for the discovery chatbot model
# (see fsdbench/discovery.py). Only needed when --chatbot_model starts with "clarin/".
# CLARIN_API_BASE=https://...
# CLARIN_API_KEY=...

# For non-OpenAI chatbot/server models, set the relevant LiteLLM key, e.g.:
# ANTHROPIC_API_KEY=sk-ant-...
